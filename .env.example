# ===========================================
# DocRebuild AI — Environment Configuration
# ===========================================

# Application
APP_NAME=DocRebuild AI
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/docrebuild.db

# Redis
REDIS_URL=redis://localhost:6379/0

# File Storage
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs
TEMP_DIR=./data/temp
MAX_FILE_SIZE_MB=500
ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.tiff,.bmp

# Model Configuration
MODEL_CACHE_DIR=./data/models
GPU_MEMORY_LIMIT_MB=8000
DEVICE=auto  # auto, cpu, cuda, cuda:0, cuda:1

# OCR Engine Toggles
ENABLE_SURYA=true
ENABLE_PADDLEOCR=true
ENABLE_TESSERACT=true
ENABLE_EASYOCR=true
ENABLE_TROCR=true
ENABLE_DOCTR=true

# Layout Engine Toggles
ENABLE_DOCLAYOUT_YOLO=true
ENABLE_LAYOUT_PARSER=true
ENABLE_DETECTRON2=true

# Understanding Engine Toggles
ENABLE_DOCLING=true
ENABLE_MARKER=true
ENABLE_NOUGAT=true

# Vision Model Toggles
ENABLE_FLORENCE2=true
ENABLE_QWEN_VL=false
ENABLE_INTERNVL=false

# Table Extraction Toggles
ENABLE_TABLE_TRANSFORMER=true
ENABLE_CAMELOT=true
ENABLE_TABULA=true

# Math Recognition Toggles
ENABLE_PIX2TEX=true
ENABLE_LATEX_OCR=true

# Bangla Validation
ENABLE_BANGLA_VALIDATION=true
BANGLA_DICTIONARY_PATH=./data/bangla_dictionary.txt

# Processing
DEFAULT_DPI=300
OCR_CONFIDENCE_THRESHOLD=0.7
VISION_VALIDATION_THRESHOLD=0.6
MAX_REPAIR_PASSES=3
ENSEMBLE_MIN_ENGINES=3

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json

# Frontend
VITE_API_URL=
VITE_WS_URL=
